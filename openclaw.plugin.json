{
  "id": "openclaw-channel",
  "name": "Infiai Channel",
  "version": "0.3.2",
  "description": "Infiai protocol channel for OpenClaw",
  "author": "openclaw-infiai",
  "channels": [
    "infiai"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "token": {
        "type": "string",
        "description": "Infiai JWT token (used to derive userID/platformID when omitted)"
      },
      "wsAddr": {
        "type": "string",
        "description": "Infiai WebSocket endpoint, e.g. ws://127.0.0.1:10001"
      },
      "apiAddr": {
        "type": "string",
        "description": "Infiai API endpoint, e.g. http://127.0.0.1:10002"
      },
      "requireMention": {
        "type": "boolean",
        "default": true,
        "description": "Whether replies in groups require mentioning the current account"
      },
      "inboundWhitelist": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [],
        "description": "Optional sender whitelist. When set, only direct messages from listed users or their @mentions in groups are processed."
      },
      "accounts": {
        "type": "object",
        "description": "Multi-account configuration keyed by accountId",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "token": {
              "type": "string",
              "description": "Infiai JWT token"
            },
            "wsAddr": {
              "type": "string"
            },
            "apiAddr": {
              "type": "string"
            },
            "requireMention": {
              "type": "boolean",
              "default": true
            },
            "inboundWhitelist": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "token": {
      "label": "Token",
      "sensitive": true
    },
    "wsAddr": {
      "label": "WebSocket Endpoint",
      "placeholder": "ws://127.0.0.1:10001"
    },
    "apiAddr": {
      "label": "API Endpoint",
      "placeholder": "http://127.0.0.1:10002"
    },
    "requireMention": {
      "label": "Require Mention in Group"
    },
    "inboundWhitelist": {
      "label": "Inbound Sender Whitelist"
    }
  }
}
