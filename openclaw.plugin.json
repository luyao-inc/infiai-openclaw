{
  "id": "openclaw-channel",
  "name": "Infiai Channel",
  "version": "0.3.2",
  "description": "Infiai protocol channel for OpenClaw",
  "author": "openclaw-infiai",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "infiai_send_text",
      "infiai_list_my_friends",
      "infiai_list_my_groups",
      "infiai_search_people",
      "infiai_search_groups",
      "infiai_apply_friends",
      "infiai_apply_groups",
      "infiai_list_group_members",
      "infiai_get_friend_chat_history",
      "infiai_get_group_chat_history",
      "infiai_get_task_context",
      "infiai_send_image",
      "infiai_send_video",
      "infiai_send_file"
    ]
  },
  "channels": [
    "infiai"
  ],
  "channelConfigs": {
    "infiai": {
      "schema": {
        "type": "object"
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "token": {
        "type": "string",
        "description": "Infiai JWT token (used to derive userID/platformID when omitted)"
      },
      "userID": {
        "type": "string",
        "description": "Infiai/OpenIM userID for the current account"
      },
      "wsAddr": {
        "type": "string",
        "description": "Infiai WebSocket endpoint, e.g. ws://127.0.0.1:10001"
      },
      "apiAddr": {
        "type": "string",
        "description": "Infiai API endpoint, e.g. http://127.0.0.1:10002"
      },
      "chatApiAddr": {
        "type": "string",
        "description": "Infiai Chat API endpoint for business tools, e.g. http://127.0.0.1:10008"
      },
      "platformID": {
        "type": "number",
        "description": "Infiai/OpenIM platformID for the current account"
      },
      "requireMention": {
        "type": "boolean",
        "default": true,
        "description": "Whether replies in groups require mentioning the current account"
      },
      "inboundWhitelist": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [],
        "description": "Optional sender whitelist. When set, only direct messages from listed users or their @mentions in groups are processed."
      },
      "accounts": {
        "type": "object",
        "description": "Multi-account configuration keyed by accountId",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "token": {
              "type": "string",
              "description": "Infiai JWT token"
            },
            "userID": {
              "type": "string"
            },
            "wsAddr": {
              "type": "string"
            },
            "apiAddr": {
              "type": "string"
            },
            "chatApiAddr": {
              "type": "string"
            },
            "platformID": {
              "type": "number"
            },
            "requireMention": {
              "type": "boolean",
              "default": true
            },
            "inboundWhitelist": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "token": {
      "label": "Token",
      "sensitive": true
    },
    "wsAddr": {
      "label": "WebSocket Endpoint",
      "placeholder": "ws://127.0.0.1:10001"
    },
    "apiAddr": {
      "label": "API Endpoint",
      "placeholder": "http://127.0.0.1:10002"
    },
    "chatApiAddr": {
      "label": "Chat API Endpoint",
      "placeholder": "http://127.0.0.1:10008"
    },
    "requireMention": {
      "label": "Require Mention in Group"
    },
    "inboundWhitelist": {
      "label": "Inbound Sender Whitelist"
    }
  }
}
