{
  "name": "@luyao-inc/infiai-openclaw",
  "version": "0.3.2",
  "description": "Infiai channel plugin for OpenClaw gateway",
  "license": "AGPL-3.0-only",
  "author": "blooming",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/luyao-inc/infiai-openclaw.git"
  },
  "homepage": "https://github.com/luyao-inc/infiai-openclaw#readme",
  "bugs": {
    "url": "https://github.com/luyao-inc/infiai-openclaw/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "README.zh-CN.md"
  ],
  "openclaw": {
    "activation": {
      "onStartup": true
    },
    "extensions": [
      "./dist/index.js"
    ],
    "contracts": {
      "tools": [
        "infiai_send_text",
        "infiai_list_my_friends",
        "infiai_list_my_groups",
        "infiai_search_people",
        "infiai_search_groups",
        "infiai_apply_friends",
        "infiai_apply_groups",
        "infiai_list_group_members",
        "infiai_get_friend_chat_history",
        "infiai_get_group_chat_history",
        "infiai_get_task_context",
        "infiai_send_image",
        "infiai_send_video",
        "infiai_send_file"
      ]
    },
    "channels": [
      "infiai"
    ],
    "channelConfigs": {
      "infiai": {
        "schema": {
          "type": "object"
        }
      }
    },
    "channel": {
      "id": "infiai",
      "label": "Infiai",
      "selectionLabel": "Infiai",
      "docsPath": "/channels/infiai",
      "blurb": "Infiai protocol channel via official SDK",
      "order": 86,
      "aliases": [
        "infiai",
        "im"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "test:connect": "tsx scripts/test-connect.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@openim/client-sdk": "^3.8.3"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "clawdbot": {
      "optional": true
    },
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
