{
  "name": "@luyao-inc/infiai-openclaw",
  "version": "0.3.2",
  "description": "Infiai channel plugin for OpenClaw gateway",
  "license": "AGPL-3.0-only",
  "author": "blooming",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/luyao-inc/infiai-openclaw.git"
  },
  "homepage": "https://github.com/luyao-inc/infiai-openclaw#readme",
  "bugs": {
    "url": "https://github.com/luyao-inc/infiai-openclaw/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "README.zh-CN.md"
  ],
  "openclaw": {
    "activation": {
      "onStartup": true
    },
    "extensions": [
      "./dist/index.js"
    ],
    "contracts": {
      "tools": [
        "infiai_send_text",
        "infiai_list_my_friends",
        "infiai_list_my_groups",
        "infiai_search_people",
        "infiai_search_groups",
        "infiai_apply_friends",
        "infiai_apply_groups",
        "infiai_list_group_members",
        "infiai_get_friend_chat_history",
        "infiai_get_group_chat_history",
        "infiai_get_task_context",
        "infiai_send_image",
        "infiai_send_video",
        "infiai_send_file"
      ]
    },
    "channels": [
      "infiai"
    ],
    "channelConfigs": {
      "infiai": {
        "label": "Infiai",
        "description": "Infiai/OpenIM channel configuration. Managed agents should route through explicit bindings.match.accountId; default is a disabled sentinel.",
        "schema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "defaultAccount": {
              "type": "string",
              "default": "default"
            },
            "token": {
              "type": "string"
            },
            "wsAddr": {
              "type": "string"
            },
            "apiAddr": {
              "type": "string"
            },
            "chatApiAddr": {
              "type": "string"
            },
            "userID": {
              "type": "string"
            },
            "platformID": {
              "type": "number"
            },
            "requireMention": {
              "type": "boolean",
              "default": true
            },
            "inboundWhitelist": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "accounts": {
              "type": "object",
              "default": {},
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "default": true
                  },
                  "token": {
                    "type": "string"
                  },
                  "wsAddr": {
                    "type": "string"
                  },
                  "apiAddr": {
                    "type": "string"
                  },
                  "chatApiAddr": {
                    "type": "string"
                  },
                  "userID": {
                    "type": "string"
                  },
                  "platformID": {
                    "type": "number"
                  },
                  "requireMention": {
                    "type": "boolean",
                    "default": true
                  },
                  "inboundWhitelist": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "default": []
                  }
                }
              }
            }
          }
        }
      }
    },
    "channelEnvVars": {
      "infiai": [
        "INFIAI_TOKEN",
        "OPENIM_TOKEN",
        "INFIAI_WS_ADDR",
        "OPENIM_WS_ADDR",
        "INFIAI_API_ADDR",
        "OPENIM_API_ADDR",
        "INFIAI_CHAT_API_ADDR",
        "CHAT_API_ADDR",
        "INFIAI_USER_ID",
        "OPENIM_USER_ID",
        "INFIAI_PLATFORM_ID",
        "OPENIM_PLATFORM_ID",
        "OPENCLAW_SHARED_SECRET",
        "INFIAI_TOOL_SHARED_SECRET"
      ]
    },
    "toolMetadata": {
      "infiai_send_text": {
        "description": "Send a text message through the configured Infiai account."
      },
      "infiai_send_image": {
        "description": "Send an image message through the configured Infiai account."
      },
      "infiai_send_video": {
        "description": "Send a video message through the configured Infiai account."
      },
      "infiai_send_file": {
        "description": "Send a file message through the configured Infiai account."
      },
      "infiai_list_my_friends": {
        "description": "List friends for the configured Infiai account."
      },
      "infiai_list_my_groups": {
        "description": "List groups for the configured Infiai account."
      },
      "infiai_search_people": {
        "description": "Search Infiai/OpenIM users."
      },
      "infiai_search_groups": {
        "description": "Search Infiai/OpenIM groups."
      },
      "infiai_apply_friends": {
        "description": "Apply to add an Infiai/OpenIM friend."
      },
      "infiai_apply_groups": {
        "description": "Apply to join an Infiai/OpenIM group."
      },
      "infiai_list_group_members": {
        "description": "List members for an Infiai/OpenIM group."
      },
      "infiai_get_friend_chat_history": {
        "description": "Read friend chat history for the configured Infiai account."
      },
      "infiai_get_group_chat_history": {
        "description": "Read group chat history for the configured Infiai account."
      },
      "infiai_get_task_context": {
        "description": "Read task context from Infiai Chat API for the configured account."
      }
    },
    "channel": {
      "id": "infiai",
      "label": "Infiai",
      "selectionLabel": "Infiai",
      "docsPath": "/channels/infiai",
      "blurb": "Infiai protocol channel via official SDK",
      "order": 86,
      "aliases": [
        "infiai",
        "im"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tsx --test src/*.test.ts",
    "test:connect": "tsx scripts/test-connect.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@openim/client-sdk": "^3.8.3"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "clawdbot": {
      "optional": true
    },
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
